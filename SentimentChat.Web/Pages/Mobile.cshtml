@page
@model MobileModel
@{
    ViewData["Title"] = "Mobile Screen";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mobile Screen - User Interface</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        :root {
            --mobile-bg: #0a0a0a;
            --mobile-header: #1a1a1a;
            --mobile-chat: #0f1419;
            --user-bubble: #008069;
            --bot-bubble: #202c33;
            --text-primary: #e9edef;
            --text-secondary: #8696a0;
            --border-color: #2a3942;
            --positive: #25d366;
            --negative: #dc3545;
            --neutral: #6c757d;
        }

        body {
            background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 100%);
            color: var(--text-primary);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            height: 100vh;
            margin: 0;
            overflow: hidden;
        }

        .mobile-container {
            max-width: 400px;
            height: 100vh;
            margin: 0 auto;
            background: var(--mobile-bg);
            border: 1px solid var(--border-color);
            display: flex;
            flex-direction: column;
        }

        .mobile-header {
            background: var(--mobile-header);
            padding: 1rem;
            border-bottom: 1px solid var(--border-color);
            text-align: center;
        }

        .mobile-header h5 {
            margin: 0;
            color: var(--positive);
            font-size: 1.2rem;
        }

        .mobile-header small {
            color: var(--text-secondary);
            font-size: 0.8rem;
        }

        .chat-messages {
            flex: 1;
            overflow-y: auto;
            padding: 1rem;
            background: var(--mobile-chat);
            scroll-behavior: smooth;
        }

        .message {
            margin-bottom: 1rem;
            display: flex;
            align-items: flex-start;
            animation: fadeIn 0.3s ease-in;
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .message.user {
            justify-content: flex-end;
        }

        .message.bot {
            justify-content: flex-start;
        }

        .message-bubble {
            max-width: 80%;
            padding: 0.75rem 1rem;
            border-radius: 1rem;
            position: relative;
            word-wrap: break-word;
        }

        .message.user .message-bubble {
            background: var(--user-bubble);
            color: white;
            border-bottom-right-radius: 0.25rem;
        }

        .message.bot .message-bubble {
            background: var(--bot-bubble);
            color: var(--text-primary);
            border-bottom-left-radius: 0.25rem;
        }

        .message-info {
            font-size: 0.7rem;
            color: var(--text-secondary);
            margin-top: 0.25rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .sentiment-badge {
            padding: 0.2rem 0.4rem;
            border-radius: 1rem;
            font-size: 0.6rem;
            font-weight: 600;
        }

        .sentiment-positive { background: var(--positive); color: white; }
        .sentiment-negative { background: var(--negative); color: white; }
        .sentiment-neutral { background: var(--neutral); color: white; }

        .mobile-input {
            background: var(--mobile-header);
            padding: 1rem;
            border-top: 1px solid var(--border-color);
        }

        .input-group {
            display: flex;
            gap: 0.5rem;
        }

        .form-control {
            background: var(--mobile-chat);
            border: 1px solid var(--border-color);
            color: var(--text-primary);
            border-radius: 2rem;
            padding: 0.75rem 1rem;
            font-size: 0.9rem;
        }

        .form-control:focus {
            background: var(--mobile-chat);
            border-color: var(--positive);
            color: var(--text-primary);
            box-shadow: 0 0 0 0.2rem rgba(37, 211, 102, 0.25);
        }

        .btn-send {
            background: var(--positive);
            border: none;
            color: white;
            border-radius: 50%;
            width: 2.5rem;
            height: 2.5rem;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
        }

        .btn-send:hover {
            background: #128c7e;
            transform: scale(1.05);
        }

        .status-indicator {
            position: absolute;
            top: 10px;
            right: 10px;
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: var(--positive);
            animation: pulse 2s infinite;
        }

        @@keyframes pulse {
            0% { opacity: 1; }
            50% { opacity: 0.5; }
            100% { opacity: 1; }
        }

        .connection-status {
            position: absolute;
            top: 5px;
            left: 10px;
            font-size: 0.8rem;
            color: var(--text-secondary);
        }

        .welcome-message {
            text-align: center;
            color: var(--text-secondary);
            padding: 2rem;
        }

        .welcome-message i {
            font-size: 3rem;
            color: var(--positive);
            margin-bottom: 1rem;
        }

        ::-webkit-scrollbar {
            width: 4px;
        }

        ::-webkit-scrollbar-track {
            background: var(--mobile-chat);
        }

        ::-webkit-scrollbar-thumb {
            background: var(--border-color);
            border-radius: 2px;
        }
    </style>
</head>
<body>
    <div class="mobile-container">
        <div class="mobile-header">
            <div class="connection-status" id="connectionStatus">
                <i class="fas fa-circle text-success"></i> Connected
            </div>
            <div class="status-indicator"></div>
            <h5><i class="fas fa-mobile-alt me-2"></i>Mobile Screen</h5>
            <small>User Interface</small>
        </div>

        <div class="chat-messages" id="chatMessages">
            <div class="welcome-message">
                <i class="fas fa-comments"></i>
                <p>Type a message to start chatting!</p>
                <small>Your message will be analyzed for sentiment on the server</small>
            </div>
        </div>

        <div class="mobile-input">
            <div class="input-group">
                <input type="text" class="form-control" id="messageInput" 
                       placeholder="Type your message..." maxlength="200">
                <button class="btn-send" id="sendButton" type="button">
                    <i class="fas fa-paper-plane"></i>
                </button>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        // Connection to SignalR hub
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/chatHub")
            .build();

        let messageId = 0;

        // Update connection status
        function updateConnectionStatus(connected) {
            const statusElement = document.getElementById('connectionStatus');
            if (connected) {
                statusElement.innerHTML = '<i class="fas fa-circle text-success"></i> Connected';
            } else {
                statusElement.innerHTML = '<i class="fas fa-circle text-danger"></i> Disconnected';
            }
        }

        // Add message to chat
        function addMessage(message) {
            const chatMessages = document.getElementById('chatMessages');
            
            // Remove welcome message if it exists
            const welcomeMsg = chatMessages.querySelector('.welcome-message');
            if (welcomeMsg) {
                welcomeMsg.remove();
            }
            
            const messageDiv = document.createElement('div');
            messageDiv.className = `message ${message.sender.toLowerCase()}`;
            
            const sentimentClass = `sentiment-${message.sentiment.toLowerCase()}`;
            
            messageDiv.innerHTML = `
                <div class="message-bubble">
                    <div>${message.text}</div>
                    <div class="message-info">
                        <span>${message.sender}</span>
                        <span>${new Date(message.timestamp).toLocaleTimeString()}</span>
                        <span class="sentiment-badge ${sentimentClass}">
                            ${message.sentimentEmoji} ${message.sentiment}
                        </span>
                    </div>
                </div>
            `;
            
            chatMessages.appendChild(messageDiv);
            chatMessages.scrollTop = chatMessages.scrollHeight;
        }

        // Handle incoming messages
        connection.on("ReceiveMessage", (message) => {
            addMessage(message);
        });

        // Send message
        async function sendMessage() {
            const input = document.getElementById('messageInput');
            const text = input.value.trim();
            
            if (!text) return;
            
            const message = {
                id: (++messageId).toString(),
                text: text,
                sender: 'Mobile User',
                timestamp: new Date().toISOString(),
                sentiment: 'Processing...',
                sentimentEmoji: '⏳',
                confidence: 0
            };
            
            // Add message immediately to UI
            addMessage(message);
            input.value = '';
            
            try {
                const response = await fetch('/api/chat/message', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(message)
                });
                
                if (!response.ok) {
                    throw new Error('Failed to send message');
                }
            } catch (error) {
                console.error('Error sending message:', error);
                alert('Failed to send message. Please check connection.');
            }
        }

        // Event listeners
        document.getElementById('sendButton').addEventListener('click', sendMessage);
        document.getElementById('messageInput').addEventListener('keypress', (e) => {
            if (e.key === 'Enter') {
                sendMessage();
            }
        });

        // Connection events
        connection.onreconnected(() => {
            updateConnectionStatus(true);
        });

        connection.onreconnecting(() => {
            updateConnectionStatus(false);
        });

        connection.onclose(() => {
            updateConnectionStatus(false);
        });

        // Start connection
        connection.start()
            .then(() => {
                updateConnectionStatus(true);
                console.log('Connected to SignalR hub');
            })
            .catch(err => {
                updateConnectionStatus(false);
                console.error('SignalR connection error:', err);
            });
    </script>
</body>
</html>
