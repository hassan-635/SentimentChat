@page
@model BotModel
@{
    ViewData["Title"] = "Bot Screen";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bot Screen - AI Response Center</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        :root {
            --bot-bg: #0a0a0a;
            --bot-panel: #1a1a1a;
            --bot-accent: #6f42c1;
            --bot-positive: #25d366;
            --bot-negative: #dc3545;
            --bot-neutral: #6c757d;
            --text-primary: #e9edef;
            --text-secondary: #8696a0;
            --border-color: #2a3942;
        }

        body {
            background: linear-gradient(135deg, #0a0a0a 0%, #2a0845 100%);
            color: var(--text-primary);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            height: 100vh;
            margin: 0;
            overflow: hidden;
        }

        .bot-container {
            height: 100vh;
            display: flex;
            flex-direction: column;
            max-width: 1200px;
            margin: 0 auto;
            background: var(--bot-bg);
        }

        .bot-header {
            background: var(--bot-panel);
            padding: 1rem;
            border-bottom: 2px solid var(--bot-accent);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .bot-title {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .bot-title h5 {
            margin: 0;
            color: var(--bot-accent);
            font-size: 1.5rem;
            font-weight: bold;
        }

        .bot-status {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .status-light {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background: var(--bot-accent);
            animation: pulse 2s infinite;
        }

        @@keyframes pulse {
            0% { opacity: 1; box-shadow: 0 0 0 0 rgba(111, 66, 193, 0.7); }
            70% { opacity: 1; box-shadow: 0 0 0 10px rgba(111, 66, 193, 0); }
            100% { opacity: 1; box-shadow: 0 0 0 0 rgba(111, 66, 193, 0); }
        }

        .bot-content {
            flex: 1;
            display: flex;
            gap: 1rem;
            padding: 1rem;
            overflow: hidden;
        }

        .response-panel {
            flex: 2;
            background: var(--bot-panel);
            border: 1px solid var(--border-color);
            border-radius: 0.5rem;
            display: flex;
            flex-direction: column;
        }

        .sentiment-panel {
            flex: 1;
            background: var(--bot-panel);
            border: 1px solid var(--border-color);
            border-radius: 0.5rem;
            padding: 1rem;
        }

        .panel-header {
            background: rgba(111, 66, 193, 0.1);
            padding: 0.75rem 1rem;
            border-bottom: 1px solid var(--border-color);
            font-weight: bold;
            color: var(--bot-accent);
        }

        .bot-responses {
            flex: 1;
            overflow-y: auto;
            padding: 1rem;
        }

        .response-item {
            margin-bottom: 1rem;
            padding: 1rem;
            border-radius: 0.5rem;
            border-left: 4px solid var(--bot-accent);
            background: rgba(111, 66, 193, 0.05);
            animation: slideIn 0.5s ease-out;
        }

        @@keyframes slideIn {
            from { opacity: 0; transform: translateX(20px); }
            to { opacity: 1; transform: translateX(0); }
        }

        .response-item.positive {
            border-left-color: var(--bot-positive);
            background: rgba(37, 211, 102, 0.05);
        }

        .response-item.negative {
            border-left-color: var(--bot-negative);
            background: rgba(220, 53, 69, 0.05);
        }

        .response-item.neutral {
            border-left-color: var(--bot-neutral);
            background: rgba(108, 117, 125, 0.05);
        }

        .response-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 0.5rem;
        }

        .response-sentiment {
            padding: 0.25rem 0.75rem;
            border-radius: 1rem;
            font-size: 0.8rem;
            font-weight: bold;
            color: white;
        }

        .sentiment-positive { background: var(--bot-positive); }
        .sentiment-negative { background: var(--bot-negative); }
        .sentiment-neutral { background: var(--bot-neutral); }

        .response-time {
            color: var(--text-secondary);
            font-size: 0.8rem;
        }

        .response-text {
            color: var(--text-primary);
            margin: 0.5rem 0;
            line-height: 1.4;
        }

        .response-meta {
            display: flex;
            gap: 1rem;
            font-size: 0.8rem;
            color: var(--text-secondary);
        }

        .bot-thinking {
            display: none;
            align-items: center;
            gap: 0.5rem;
            padding: 1rem;
            background: rgba(111, 66, 193, 0.1);
            border: 1px solid var(--bot-accent);
            border-radius: 0.5rem;
            margin-bottom: 1rem;
        }

        .bot-thinking.active {
            display: flex;
        }

        .thinking-dots {
            display: flex;
            gap: 0.25rem;
        }

        .dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--bot-accent);
            animation: bounce 1.4s infinite ease-in-out both;
        }

        .dot:nth-child(1) { animation-delay: -0.32s; }
        .dot:nth-child(2) { animation-delay: -0.16s; }

        @@keyframes bounce {
            0%, 80%, 100% { transform: scale(0); }
            40% { transform: scale(1); }
        }

        .sentiment-display {
            text-align: center;
            padding: 2rem;
        }

        .current-sentiment {
            font-size: 3rem;
            margin-bottom: 1rem;
        }

        .sentiment-label {
            font-size: 1.5rem;
            font-weight: bold;
            color: var(--text-primary);
            margin-bottom: 0.5rem;
        }

        .sentiment-description {
            color: var(--text-secondary);
            font-size: 0.9rem;
        }

        .response-stats {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1rem;
            margin-top: 1rem;
        }

        .stat-item {
            text-align: center;
            padding: 1rem;
            background: rgba(111, 66, 193, 0.05);
            border-radius: 0.5rem;
        }

        .stat-value {
            font-size: 1.5rem;
            font-weight: bold;
            color: var(--text-primary);
        }

        .stat-name {
            font-size: 0.8rem;
            color: var(--text-secondary);
            margin-top: 0.25rem;
        }

        .bot-avatar {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--bot-accent), #8b5cf6);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1rem;
        }

        .bot-avatar i {
            font-size: 1.5rem;
            color: white;
        }

        ::-webkit-scrollbar {
            width: 8px;
        }

        ::-webkit-scrollbar-track {
            background: var(--bot-panel);
        }

        ::-webkit-scrollbar-thumb {
            background: var(--border-color);
            border-radius: 4px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: var(--text-secondary);
        }

        /* Responsive Design */
        @@media (max-width: 1400px) {
            .bot-header {
                padding: 0.8rem;
            }
            
            .bot-title h5 {
                font-size: 1.3rem;
            }
            
            .bot-content {
                gap: 0.8rem;
                padding: 0.8rem;
            }
        }

        @@media (max-width: 1200px) {
            .bot-header {
                padding: 0.7rem;
            }
            
            .bot-title {
                gap: 0.6rem;
            }
            
            .bot-title h5 {
                font-size: 1rem;
            }
            
            .bot-content {
                gap: 0.6rem;
                padding: 0.6rem;
                flex-direction: column;
            }
            
            .sentiment-panel {
                flex: 1 !important;
                padding: 0.8rem;
            }
            
            .response-panel {
                flex: 2 !important;
                min-height: 350px;
            }
        }

        @@media (max-width: 1024px) {
            .bot-content {
                gap: 0.5rem;
                padding: 0.5rem;
            }
            
            .response-panel {
                min-height: 300px;
            }
            
            .bot-responses {
                padding: 0.6rem;
            }
            
            .bot-title i {
                font-size: 1.5rem;
            }
            
            .response-item {
                padding: 0.8rem;
                margin-bottom: 0.6rem;
            }
            
            .response-sentiment {
                font-size: 0.75rem;
            }
            
            .response-text {
                font-size: 0.9rem;
            }
        }

        @@media (max-width: 768px) {
            .bot-container {
                height: 100vh;
                overflow: hidden;
                display: flex;
                flex-direction: column;
            }
            
            .bot-header {
                padding: 0.5rem;
                border-bottom-width: 1px;
                flex-direction: column;
                gap: 0.4rem;
                align-items: flex-start;
            }
            
            .bot-title {
                width: 100%;
                gap: 0.4rem;
            }
            
            .bot-title i {
                font-size: 1.2rem;
            }
            
            .bot-title h5 {
                font-size: 0.95rem;
                margin: 0;
            }
            
            .bot-title small {
                font-size: 0.7rem;
            }
            
            .bot-status {
                width: 100%;
                justify-content: space-between;
                font-size: 0.75rem;
            }
            
            .status-light {
                width: 10px;
                height: 10px;
            }
            
            .bot-content {
                flex: 1;
                gap: 0.4rem;
                padding: 0.4rem;
                overflow: hidden;
                flex-direction: column;
            }
            
            .response-panel {
                flex: 1;
                min-height: 0;
                border-radius: 0.4rem;
            }
            
            .sentiment-panel {
                flex: 0 0 auto;
                padding: 0.6rem;
                border-radius: 0.4rem;
                max-height: 200px;
                overflow-y: auto;
            }
            
            .panel-header {
                padding: 0.5rem 0.7rem;
                font-size: 0.8rem;
            }
            
            .panel-header i {
                font-size: 0.8rem;
            }
            
            .bot-responses {
                padding: 0.5rem;
                flex: 1;
                overflow-y: auto;
            }
            
            .response-item {
                padding: 0.6rem;
                margin-bottom: 0.5rem;
                border-left-width: 3px;
                font-size: 0.8rem;
            }
            
            .response-header {
                margin-bottom: 0.3rem;
                font-size: 0.75rem;
            }
            
            .response-sentiment {
                padding: 0.2rem 0.5rem;
                font-size: 0.65rem;
            }
            
            .response-time {
                font-size: 0.65rem;
            }
            
            .response-text {
                font-size: 0.8rem;
                margin: 0.3rem 0;
                line-height: 1.3;
            }
            
            .response-meta {
                gap: 0.5rem;
                font-size: 0.7rem;
            }
            
            .bot-thinking {
                padding: 0.6rem;
                gap: 0.4rem;
                font-size: 0.75rem;
                margin-bottom: 0.5rem;
                border-left: 3px solid var(--bot-accent);
            }
            
            .thinking-dots .dot {
                width: 6px;
                height: 6px;
            }
            
            .sentiment-display {
                padding: 1rem 0.5rem;
                text-align: center;
            }
            
            .current-sentiment {
                font-size: 2rem;
                margin-bottom: 0.4rem;
            }
            
            .sentiment-label {
                font-size: 1rem;
                margin-bottom: 0.3rem;
            }
            
            .sentiment-description {
                font-size: 0.75rem;
            }
            
            .response-stats {
                grid-template-columns: repeat(2, 1fr);
                gap: 0.5rem;
                margin-top: 0.5rem;
            }
            
            .stat-item {
                padding: 0.5rem;
                font-size: 0.75rem;
            }
            
            .stat-value {
                font-size: 1rem;
            }
            
            .stat-name {
                font-size: 0.65rem;
                margin-top: 0.1rem;
            }
            
            .bot-avatar {
                width: 45px;
                height: 45px;
                margin: 0 auto 0.5rem;
            }
            
            .bot-avatar i {
                font-size: 1.1rem;
            }
            
            .text-center h6 {
                font-size: 0.9rem;
                margin: 0.3rem 0;
            }
            
            .text-center p {
                font-size: 0.8rem;
                margin: 0.2rem 0;
            }
            
            .text-center small {
                font-size: 0.65rem;
            }
        }

        @@media (max-width: 600px) {
            .bot-header {
                padding: 0.4rem;
            }
            
            .bot-title i {
                font-size: 1rem;
            }
            
            .bot-title h5 {
                font-size: 0.85rem;
            }
            
            .bot-title small {
                font-size: 0.6rem;
            }
            
            .bot-status {
                font-size: 0.65rem;
            }
            
            .bot-content {
                gap: 0.3rem;
                padding: 0.3rem;
            }
            
            .response-panel {
                border-radius: 0.3rem;
            }
            
            .sentiment-panel {
                padding: 0.5rem;
                border-radius: 0.3rem;
            }
            
            .panel-header {
                padding: 0.4rem 0.6rem;
                font-size: 0.7rem;
            }
            
            .response-item {
                padding: 0.5rem;
                margin-bottom: 0.4rem;
                font-size: 0.75rem;
            }
            
            .sentiment-display {
                padding: 0.8rem 0.3rem;
            }
            
            .current-sentiment {
                font-size: 1.6rem;
            }
            
            .sentiment-label {
                font-size: 0.9rem;
            }
            
            .sentiment-description {
                font-size: 0.7rem;
            }
            
            .response-stats {
                gap: 0.4rem;
                margin-top: 0.4rem;
            }
            
            .stat-item {
                padding: 0.4rem;
                font-size: 0.65rem;
            }
            
            .stat-value {
                font-size: 0.9rem;
            }
            
            .bot-avatar {
                width: 40px;
                height: 40px;
            }
            
            .bot-avatar i {
                font-size: 1rem;
            }
        }

        @@media (max-width: 480px) {
            .bot-header {
                padding: 0.3rem;
                gap: 0.3rem;
            }
            
            .bot-title {
                width: 100%;
                gap: 0.3rem;
            }
            
            .bot-title i {
                font-size: 0.9rem;
            }
            
            .bot-title h5 {
                font-size: 0.75rem;
            }
            
            .bot-title small {
                display: none;
            }
            
            .bot-status {
                width: 100%;
                font-size: 0.6rem;
            }
            
            .bot-content {
                gap: 0.25rem;
                padding: 0.25rem;
            }
            
            .panel-header {
                padding: 0.3rem 0.5rem;
                font-size: 0.65rem;
            }
            
            .bot-responses {
                padding: 0.3rem;
            }
            
            .response-item {
                padding: 0.4rem;
                margin-bottom: 0.3rem;
                font-size: 0.7rem;
            }
            
            .response-sentiment {
                padding: 0.15rem 0.4rem;
                font-size: 0.6rem;
            }
            
            .response-text {
                font-size: 0.7rem;
                margin: 0.2rem 0;
            }
            
            .sentiment-display {
                padding: 0.6rem 0.3rem;
            }
            
            .current-sentiment {
                font-size: 1.4rem;
            }
            
            .sentiment-label {
                font-size: 0.8rem;
            }
            
            .sentiment-description {
                font-size: 0.65rem;
            }
            
            .response-stats {
                grid-template-columns: repeat(2, 1fr);
                gap: 0.3rem;
                margin-top: 0.3rem;
            }
            
            .stat-item {
                padding: 0.3rem;
                font-size: 0.6rem;
            }
            
            .stat-value {
                font-size: 0.8rem;
            }
            
            .stat-name {
                font-size: 0.55rem;
            }
            
            .bot-avatar {
                width: 35px;
                height: 35px;
                margin: 0 auto 0.3rem;
            }
            
            .bot-avatar i {
                font-size: 0.8rem;
            }
        }

        @@media (max-width: 360px) {
            .bot-title h5 {
                font-size: 0.65rem;
            }
            
            .bot-title i {
                display: none;
            }
            
            .bot-status {
                font-size: 0.55rem;
            }
            
            .panel-header {
                font-size: 0.6rem;
            }
            
            .panel-header i {
                display: none;
            }
            
            .response-item {
                font-size: 0.65rem;
            }
            
            .current-sentiment {
                font-size: 1.2rem;
            }
            
            .sentiment-label {
                font-size: 0.7rem;
            }
        }
    </style>
</head>
<body>
    <div class="bot-container">
        <div class="bot-header">
            <div class="bot-title">
                <i class="fas fa-robot fa-2x"></i>
                <div>
                    <h5><i class="fas fa-brain me-2"></i>BOT SCREEN</h5>
                    <small class="text-secondary">AI Response Center</small>
                </div>
            </div>
            <div class="bot-status">
                <div class="status-light"></div>
                <span>AI ACTIVE</span>
            </div>
        </div>

        <div class="bot-content">
            <div class="response-panel">
                <div class="panel-header">
                    <i class="fas fa-comments me-2"></i>AI RESPONSES
                </div>
                
                <div class="bot-thinking" id="botThinking">
                    <div class="thinking-dots">
                        <div class="dot"></div>
                        <div class="dot"></div>
                        <div class="dot"></div>
                    </div>
                    <span>Bot is thinking...</span>
                </div>

                <div class="bot-responses" id="botResponses">
                    <div class="text-center text-secondary py-5">
                        <div class="bot-avatar">
                            <i class="fas fa-robot"></i>
                        </div>
                        <h6>AI Bot Ready</h6>
                        <p>Waiting for messages from Server...</p>
                        <small>Responses will appear here with matching sentiment</small>
                    </div>
                </div>
            </div>

            <div class="sentiment-panel">
                <div class="panel-header">
                    <i class="fas fa-heart me-2"></i>CURRENT SENTIMENT
                </div>
                
                <div class="sentiment-display">
                    <div class="current-sentiment" id="currentSentimentEmoji">🤖</div>
                    <div class="sentiment-label" id="currentSentimentLabel">Ready</div>
                    <div class="sentiment-description" id="currentSentimentDesc">Waiting for messages</div>
                </div>

                <div class="response-stats">
                    <div class="stat-item">
                        <div class="stat-value" id="totalResponses">0</div>
                        <div class="stat-name">Total Responses</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-value" id="avgResponseTime">0s</div>
                        <div class="stat-name">Avg Response Time</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-value" id="positiveResponses">0</div>
                        <div class="stat-name">Positive</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-value" id="negativeResponses">0</div>
                        <div class="stat-name">Negative</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        // Connection to SignalR hub
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/chatHub")
            .build();

        // Bot statistics
        let botStats = {
            total: 0,
            positive: 0,
            negative: 0,
            neutral: 0,
            totalTime: 0
        };

        // Update sentiment display
        function updateSentimentDisplay(sentiment, emoji, confidence) {
            document.getElementById('currentSentimentEmoji').textContent = emoji;
            document.getElementById('currentSentimentLabel').textContent = sentiment;
            
            let description = '';
            if (sentiment === 'Positive') {
                description = `Responding with positive energy (${Math.round(confidence * 100)}% confidence)`;
            } else if (sentiment === 'Negative') {
                description = `Responding with understanding (${Math.round(confidence * 100)}% confidence)`;
            } else {
                description = `Responding neutrally (${Math.round(confidence * 100)}% confidence)`;
            }
            document.getElementById('currentSentimentDesc').textContent = description;
        }

        // Update bot statistics
        function updateBotStats() {
            document.getElementById('totalResponses').textContent = botStats.total;
            document.getElementById('positiveResponses').textContent = botStats.positive;
            document.getElementById('negativeResponses').textContent = botStats.negative;
            
            const avgTime = botStats.total > 0 ? (botStats.totalTime / botStats.total).toFixed(1) : 0;
            document.getElementById('avgResponseTime').textContent = avgTime + 's';
        }

        // Add bot response
        function addBotResponse(message) {
            const responses = document.getElementById('botResponses');
            
            // Remove welcome message if it exists
            const welcomeMsg = responses.querySelector('.text-center');
            if (welcomeMsg) {
                welcomeMsg.remove();
            }
            
            const responseDiv = document.createElement('div');
            responseDiv.className = `response-item ${message.sentiment.toLowerCase()}`;
            
            const sentimentClass = `sentiment-${message.sentiment.toLowerCase()}`;
            
            responseDiv.innerHTML = `
                <div class="response-header">
                    <span class="response-sentiment ${sentimentClass}">
                        ${message.sentimentEmoji} ${message.sentiment}
                    </span>
                    <span class="response-time">${new Date(message.timestamp).toLocaleTimeString()}</span>
                </div>
                <div class="response-text">${message.text}</div>
                <div class="response-meta">
                    <span><i class="fas fa-user me-1"></i>Response to: ${message.originalMessage || 'User'}</span>
                    <span><i class="fas fa-chart-line me-1"></i>Confidence: ${Math.round(message.confidence * 100)}%</span>
                </div>
            `;
            
            responses.appendChild(responseDiv);
            responses.scrollTop = responses.scrollHeight;
            
            // Update statistics
            botStats.total++;
            botStats[message.sentiment.toLowerCase()]++;
            updateBotStats();
        }

        // Handle incoming messages
        connection.on("ReceiveMessage", (message) => {
            if (message.sender === 'Bot') {
                // Hide thinking indicator
                document.getElementById('botThinking').classList.remove('active');
                
                // Update sentiment display
                updateSentimentDisplay(message.sentiment, message.sentimentEmoji, message.confidence);
                
                // Add response to list
                addBotResponse(message);
            } else if (message.sender === 'Mobile User') {
                // Show thinking indicator
                document.getElementById('botThinking').classList.add('active');
                
                // Update sentiment display for incoming message
                updateSentimentDisplay(message.sentiment, message.sentimentEmoji, message.confidence);
            }
        });

        // Start connection
        connection.start()
            .then(() => {
                console.log('Bot screen connected to SignalR hub');
            })
            .catch(err => {
                console.error('SignalR connection error:', err);
            });
    </script>
</body>
</html>
